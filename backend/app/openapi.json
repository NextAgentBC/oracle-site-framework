{
  "openapi": "3.1.0",
  "info": {
    "title": "Oracle Site API",
    "version": "0.1.0"
  },
  "servers": [
    { "url": "http://localhost:8000/api" }
  ],
  "paths": {
    "/health": { "get": { "summary": "Health check" } },
    "/site": { "get": { "summary": "Public site config" } },
    "/auth/google": { "post": { "summary": "Google signup/login" } },
    "/blogs": { "get": { "summary": "List published blog posts" } },
    "/blogs/{slug}": { "get": { "summary": "Get published blog post" } },
    "/newsletter/subscribe": { "post": { "summary": "Subscribe to newsletter" } },
    "/contact": { "post": { "summary": "Send contact message" } },
    "/admin/blogs/generate": { "post": { "summary": "Generate AI blog post" } },
    "/admin/blogs": { "post": { "summary": "Create blog post" } },
    "/admin/blogs/{id}": { "patch": { "summary": "Update blog post" } }
  }
}
