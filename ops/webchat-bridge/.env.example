# Webchat bridge config (host-side). Copy to .env (gitignored) and fill in.
# The token MUST match backend/.env WEBCHAT_BRIDGE_TOKEN.

# Shared bearer token the website backend sends as X-Bridge-Token.
WEBCHAT_BRIDGE_TOKEN=change-me-to-a-long-random-string

# Operator Telegram chat id to mirror visitor conversations to ("" disables mirror).
WEBCHAT_TG_TARGET=

# Model for the (tool-less) support brain. Any id from `openclaw infer model list`.
WEBCHAT_MODEL=default
WEBCHAT_THINKING=minimal

# Listen port (reachable from the backend container via host.docker.internal).
WEBCHAT_BRIDGE_PORT=18791

# Per-turn model timeout (seconds) and mirror toggle.
WEBCHAT_TIMEOUT=90
WEBCHAT_MIRROR=1
